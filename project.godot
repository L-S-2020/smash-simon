config_version=5

[application]

config/name="Smash Simon"
run/main_scene="uid://dg2wrcr4svg6y"
config/features=PackedStringArray("4.5", "Mobile")
boot_splash/image="uid://dva4dqdfs06ny"

[autoload]

MultiplayerInput="*res://addons/multiplayer_input/multiplayer_input.gd"
Global="*res://global.gd"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"

[display]

window/stretch/mode="canvas_items"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/health_hitbox_hurtbox/plugin.cfg", "res://addons/multiplayer_input/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

